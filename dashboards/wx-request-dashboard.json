{
  "title": "Weather Request Dashboard",
  "tags": [
    "haminfo",
    "weather",
    "requests",
    "api"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Total Weather Requests",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "haminfo"
          },
          "format": "table",
          "refId": "A",
          "rawSql": "SELECT COUNT(*) as value FROM wx_request"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Weather Requests (Last 24h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "haminfo"
          },
          "format": "table",
          "refId": "A",
          "rawSql": "SELECT COUNT(*) as value FROM wx_request WHERE created >= NOW() - INTERVAL '24 hours'"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Weather Requests Over Time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "haminfo"
          },
          "format": "time_series",
          "timeColumn": "time",
          "refId": "A",
          "rawSql": "SELECT date_trunc('hour', created) as time, COUNT(*) as value FROM wx_request WHERE created IS NOT NULL GROUP BY date_trunc('hour', created) ORDER BY time"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 100,
            "gradientMode": "none",
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Top Requesting Callsigns",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "haminfo"
          },
          "format": "table",
          "refId": "A",
          "rawSql": "SELECT callsign as \"Callsign\", COUNT(*) as \"Count\" FROM wx_request WHERE callsign IS NOT NULL AND callsign != 'None' GROUP BY callsign ORDER BY COUNT(*) DESC LIMIT 20"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Count"
          }
        ]
      }
    },
    {
      "id": 5,
      "title": "Average Stations per Request",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "haminfo"
          },
          "format": "table",
          "refId": "A",
          "rawSql": "SELECT AVG(count) as value FROM wx_request WHERE count IS NOT NULL"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          },
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Request Count Distribution",
      "type": "histogram",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "haminfo"
          },
          "format": "table",
          "refId": "A",
          "rawSql": "SELECT count FROM wx_request WHERE count IS NOT NULL ORDER BY count"
        }
      ],
      "options": {
        "bucketOffset": 0,
        "bucketSize": 1
      }
    },
    {
      "id": 7,
      "title": "Requests Per Hour",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "haminfo"
          },
          "format": "time_series",
          "timeColumn": "time",
          "refId": "A",
          "rawSql": "SELECT date_trunc('hour', created) as time, COUNT(*) as value FROM wx_request WHERE created IS NOT NULL GROUP BY date_trunc('hour', created) ORDER BY time"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      }
    }
  ],
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "weekStart": "",
  "uid": "wx-request"
}
