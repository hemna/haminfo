        "h": 10,
        "w": 12,
        "x": 12,
        "y": 30
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "haminfo"
          },
          "rawSql": "SELECT state as \"State\", freq_band as \"Band\", COUNT(*) as \"Count\" FROM station WHERE state IS NOT NULL AND country = 'United States' AND freq_band IS NOT NULL GROUP BY state, freq_band ORDER BY state, COUNT(*) DESC",
          "format": "table",
          "refId": "A"
