      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "haminfo"
          },
          "rawSql": "SELECT state as \"State\", COUNT(CASE WHEN ares = true THEN 1 END) as \"ARES\", COUNT(CASE WHEN races = true THEN 1 END) as \"RACES\", COUNT(CASE WHEN skywarn = true THEN 1 END) as \"SKYWARN\", COUNT(CASE WHEN allstar_node = true THEN 1 END) as \"AllStar\", COUNT(CASE WHEN echolink_node = true THEN 1 END) as \"EchoLink\", COUNT(CASE WHEN dmr = true THEN 1 END) as \"DMR\", COUNT(CASE WHEN dstar = true THEN 1 END) as \"D-Star\" FROM station WHERE state IS NOT NULL AND country = 'United States' GROUP BY state ORDER BY COUNT(*) DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true,
