      "id": 11,
      "title": "Stations by US State",
      "type": "barchart",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 30
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "haminfo"
          },
          "rawSql": "SELECT state as \"State\", COUNT(*) as \"Count\" FROM station WHERE state IS NOT NULL AND country = 'United States' GROUP BY state ORDER BY COUNT(*) DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
