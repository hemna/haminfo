      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "haminfo"
          },
          "rawSql": "SELECT state as \"State\", operational_status as \"Status\", COUNT(*) as \"Count\" FROM station WHERE state IS NOT NULL AND country = 'United States' AND operational_status IS NOT NULL GROUP BY state, operational_status ORDER BY state, COUNT(*) DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
