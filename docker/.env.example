# haminfo Docker environment variables
# Copy this file to .env and fill in actual values

# PostgreSQL Database
POSTGRES_DB=haminfo
POSTGRES_USER=haminfo
POSTGRES_PASSWORD=changeme_use_strong_password

# Memcached
TZ=America/New_York
MEMCACHED_CACHE_SIZE=64MB
MEMCACHED_MAX_CONNECTIONS=1024
MEMCACHED_THREADS=4
MEMCACHED_USER=memcached
MEMCACHED_PASSWORD=changeme_use_strong_password
