# Dockerfile for haminfo MQTT ingest with free-threaded Python 3.13t
# Uses uv to install Python 3.13t (no-GIL experimental build) for better
# multi-threaded performance with parallel APRS packet processors.

FROM ghcr.io/astral-sh/uv:bookworm AS prepare

ARG BRANCH
ARG COMMIT_SHA
ARG UID
ARG GID

ENV APP_GIT=https://github.com/hemna/haminfo.git
ENV APP_BRANCH=${BRANCH:-master}
ENV APP_COMMIT_SHA=${COMMIT_SHA:-}
ENV UID=${UID:-1000}
ENV GID=${GID:-1000}

# Install build dependencies (ca-certificates needed for git clone over https)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git sudo cron libmemcached-dev build-essential postgresql-client ca-certificates \
    && rm -rf /var/lib/apt/lists/*

ENV PIP_DEFAULT_TIMEOUT=100 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1

ENV LC_ALL=C.UTF-8
ENV LANG=C.UTF-8

# Stage 2: Install Python 3.13t and dependencies
FROM prepare AS install
ARG CACHEBUST

WORKDIR /app

# Install free-threaded Python 3.13t using uv
# The 't' suffix indicates the free-threaded (no-GIL) build
RUN uv python install 3.13t

# Create venv with free-threaded Python
RUN uv venv --python 3.13t
ENV VIRTUAL_ENV=/app/.venv
ENV PATH="/app/.venv/bin:$PATH"

# Upgrade pip and install wheel
RUN uv pip install -U "pip>=26.0" "virtualenv>=20.36.1" "filelock>=3.20.3" wheel

RUN mkdir /config

# Clone the repo and checkout specific commit SHA if provided
RUN echo "Cache bust: $CACHEBUST" && \
    git clone -b $APP_BRANCH $APP_GIT && \
    cd /app/haminfo && \
    if [ -n "$APP_COMMIT_SHA" ]; then \
        git fetch --unshallow 2>/dev/null || true; \
        git checkout $APP_COMMIT_SHA 2>/dev/null || echo "SHA not found, using branch HEAD"; \
    fi && \
    echo "typing-extensions>=4.15.0" > /tmp/overrides.txt && \
    cd /app && uv pip install --override /tmp/overrides.txt /app/haminfo

RUN uv pip install oslo-config
RUN mkdir -p /app/.config/haminfo
RUN uv run oslo-config-generator --namespace haminfo --namespace haminfo.db --namespace haminfo.flask --namespace oslo.log > /config/haminfo.conf

### Final stage
FROM install AS final

# Disable the GIL for free-threaded Python
# This enables true parallel execution across threads
ENV PYTHON_GIL=0

# Verify free-threaded Python is working
RUN python -c "import sys; print(f'Python {sys.version}'); import sysconfig; print(f'Free-threaded: {sysconfig.get_config_var(\"Py_GIL_DISABLED\")}')"

ENV CONF=default
VOLUME ["/config"]
EXPOSE 8081/tcp
EXPOSE 8081/udp

COPY ./bin/api_entry.sh /app/
COPY ./bin/reload_db.sh /app/
COPY ./bin/db_upgrade.sh /app/
COPY ./bin/cron_entry.sh /app/
COPY ./bin/run_mqtt.sh /app/
COPY ./bin/clean_db.sh /app/

ENTRYPOINT ["/app/run_mqtt.sh"]
